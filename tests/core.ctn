print("--- Cartan Core Verification ---");

// Test Unary and Logical Operators
var is_active: bool = false;
var score: float = -10.5;

if (!is_active || score > 0.0) {
    print("Logical OR and Unary NOT / MINUS working!");
}

var in_range = (score >= -20.0 && score <= 0.0);
if (in_range) {
    print("Logical AND working!");
}

// Test Dictionaries
var config = {
    "lr": 0.01,
    "epochs": 10,
    "name": "CartanModel"
};

print("Dictionary String Concatenation:");
var output = "Model Name is: " + config["name"];
print(output);

// Test Loop Controls
print("Testing For Loop with Break & Continue:");
var sum: int = 0;
for (var i = 0; i < 10; i = i + 1) {
    if (i == 3) {
        print("Continuing at 3...");
        continue;
    }
    if (i == 7) {
        print("Breaking at 7!");
        break;
    }
    sum = sum + i;
}

print("Final Sum (expected 0+1+2+4+5+6 = 18):");
print(sum);
