print("--- Cartan Phase 9: Advanced Language Features ---");

// 1. Modularity (Namespaced Imports)
print("[1/5] Modularity:");
var math_mod = import "math_lib.ctn";
print("Imported PI:");
print(math_mod.PI);
print("Called math_mod.add(10.0, 5.0):");
print(math_mod.add(10.0, 5.0));

// 2. Constants & Error Handling
print("");
print("[2/5] Constants and Error Handling:");
const MAX_VALUE: int = 100;
print("MAX_VALUE is:");
print(MAX_VALUE);

try {
    print("Attempting to reassign a const...");
    // We expect this to fail but we can't catch interpreter exceptions natively yet 
    // unless they are thrown by 'throw'. Interpreter errors crash python.
    // So let's test native throw instead!
    throw "Testing the native throw mechanism!";
} catch (err) {
    print("Successfully caught exception:");
    print(err);
}

// 3. Bitwise & Hex/Binary Literals
print("");
print("[3/5] Bitwise Operators and Hex/Binary:");
var hex_val = 0xFF;   // 255
var bin_val = 0b1010; // 10
print("0xFF & 0b1010:");
print(hex_val & bin_val); // Should be 10

var shifted = bin_val << 2;
print("10 << 2:");
print(shifted); // Should be 40

// 4. Array Standard Library
print("");
print("[4/5] Array Stdlib:");
var list = [1, 2, 3];
list.push(4);
print("After push(4):");
print(list);
print("Array length:");
print(list.length());
print("Popped value:");
print(list.pop());

// 5. String & Math Stdlib
print("");
print("[5/5] String & Math Stdlib:");
var text = "Cartan Language";
print("String length:");
print(text.length());
print("Substring(0, 6):");
print(text.substring(0, 6));

var power = Math.pow(2.0, 4.0);
print("Math.pow(2.0, 4.0):");
print(power);

print("");
print("Phase 9 Fully Verified!");
