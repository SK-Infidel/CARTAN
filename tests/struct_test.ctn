extern fn printf();

struct Point {
    var x = 0.0;
    var y = 0.0;
}

fn test_struct() {
    var p = Point(1.5, 2.5);
    var a = p.x;
    var b = p.y;
    printf("Point(x: %f, y: %f)\n", a, b);
    
    p.x = 10.0;
    p.y = 20.0;
    
    printf("Updated(x: %f, y: %f)\n", p.x, p.y);
}

test_struct();
