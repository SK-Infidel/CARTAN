import "optimizer.ctn";

print("--- Cartan Grand Integration Test ---");

struct DenseLayer {
    var weights: tensor = tensor[1, 1];
    var bias: tensor = tensor[1, 1];
    
    fn forward(x: tensor): tensor {
        var out = (x * weights) + bias;
        return out;
    }
}

struct NeuralNetwork {
    // Array containing multiple instances of the DenseLayer struct
    var layers = [DenseLayer(), DenseLayer()];
    
    // Static typed primitives
    var is_active: bool = true;
    var name: string = "DeepCartan";
    
    fn predict(x: tensor): tensor {
        if (is_active == false) {
            return x; // Identity pass-through
        }
        
        var i: int = 0;
        var current = x;
        
        // While loop traversing the array
        while (i < 2) {
            current = layers[i].forward(current);
            i = i + 1;
        }
        return current;
    }
}

// Instantiate the custom types
var net: NeuralNetwork = NeuralNetwork();
var opt: SGDOptimizer = SGDOptimizer();

// Deep property assignment
opt.lr = 0.05;

print("Initialized Network:");
print(net.name);

// Deep index mutation (Struct -> Array -> Struct -> Property -> Index)
net.layers[0].weights[0] = 2.0;
net.layers[0].bias[0] = 0.5;
net.layers[1].weights[0] = 3.0;
net.layers[1].bias[0] = 0.0 - 1.0;

// Inputs and Targets
var input: tensor = tensor[1, 1];
input[0] = 1.0;

var target: tensor = tensor[1, 1];
target[0] = 10.0;

print("Running Training Loop...");

var epoch: int = 0;
while (epoch < 3) {
    // Forward Pass
    var pred: tensor = net.predict(input);
    
    // Loss Computation
    var error = pred - target;
    var loss = error * error;
    
    print("Epoch Loss:");
    print(loss);
    
    // Native Reverse-Mode Autograd
    backward(loss);
    
    // Optimizer Step for each parameter
    net.layers[0].weights = opt.step(net.layers[0].weights);
    net.layers[0].bias = opt.step(net.layers[0].bias);
    net.layers[1].weights = opt.step(net.layers[1].weights);
    net.layers[1].bias = opt.step(net.layers[1].bias);
    
    epoch = epoch + 1;
}

print("Final Predictions:");
var final_pred = net.predict(input);
print(final_pred);

print("Testing Native File I/O...");
var test_string: string = "Cartan Integration Success!";
write_file("test_output.txt", test_string);

var disk_content: string = read_file("test_output.txt");
print("Read from disk:");
print(disk_content);
