struct AgentData {
    position: FloatTensor;
    velocity: FloatTensor;
}

trait Movable {
    fn update_position() {}
}

impl Movable for AgentData {
    fn update_position() {
        tensor dt[1];
        dt[0] = 0.016;
    }
}

impl AgentData {
    fn reset() {
        tensor zero[1];
        zero[0] = 0.0;
    }
}

spawn SecureDatabase {
    tensor keys[256];
    
    receive Query(q: INT32) {
        tensor result[1];
        result[0] = 1.0;
    }
}
